[
    {
        "tool_name": "create_tensor",
        "description": "Create a NumPy tensor (matrix) with a specified shape and values.",
        "arguments": {
            "shape": "list[int] (Shape of the array, e.g., [2, 3])",
            "values": "list[float] (Flat list of values to populate the array)",
            "name": "string (Name to store the tensor under)"
        },
        "returns": {
            "type": "object",
            "description": "A NumPy array with the specified shape and values."
        }
    },
    {
        "tool_name": "view_tensor",
        "description": "View an immutable copy of a stored tensor by name.",
        "arguments": {
            "name": "string (Stored tensor name)"
        },
        "returns": {
            "type": "object",
            "description": "The NumPy tensor as stored."
        }
    },
    {
        "tool_name": "delete_tensor",
        "description": "Delete a tensor from memory by name.",
        "arguments": {
            "name": "string (Stored tensor name to delete)"
        },
        "returns": {
            "type": "object",
            "description": "Confirmation of deletion or an error if not found."
        }
    },
    {
        "tool_name": "add_matrices",
        "description": "Element-wise addition of two stored tensors.",
        "arguments": {
            "name_a": "string (First tensor name)",

        },
        "returns": {
            "type": "object",
            "description": "Resulting tensor after matrix multiplication."
        }
    },
    {
        "tool_name": "scale_matrix",
        "description": "Scale a stored tensor by a scalar factor.",
        "arguments": {
            "name": "string (Tensor name to scale)",

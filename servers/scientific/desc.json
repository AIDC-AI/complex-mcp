        },
        "returns": {
            "type": "object",
            "description": "Resulting tensor after addition."
        }
    },
    {
        "tool_name": "subtract_matrices",
        "description": "Element-wise subtraction of two stored tensors: name_a - name_b.",
        "arguments": {
            "name_a": "string (First tensor name)",
            "name_b": "string (Second tensor name)"
        },
        "returns": {
            "type": "object",
            "description": "Resulting tensor after subtraction."
        }
    },
    {
        "tool_name": "multiply_matrices",
        "description": "Matrix multiplication of two stored tensors.",
        "arguments": {
            "name_a": "string (First tensor name)",
